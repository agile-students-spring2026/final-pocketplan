{
  "name": "pocketplan-backend",
  "version": "1.0.0",
  "description": "Express.js back-end for PocketPlan",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha",
    "coverage": "c8 mocha"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "c8": {
    "reporter": ["text", "lcov"],
    "include": ["app.js", "routes/**/*.js"],
    "exclude": ["test/**"]
  }
}
