    "dev": "nodemon server.js",
    "test": "mocha",
    "test:coverage": "c8 mocha"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "c8": "^9.1.0",
    "chai": "^4.4.1",
    "mocha": "^11.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "include": [
      "app.js",
      "routes/**/*.js"
    ],
    "exclude": [
      "test/**"
    ]
